# ── Required ──────────────────────────────────────────────────────────────────
# Claude Code OAuth token — get it by running on your host: claude setup-token
# The token starts with sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
API_PORT=3000
API_KEY=
CLAUDE_BIN=claude
# In Docker this is set to /app/src/claude automatically via docker-compose.yml
CLAUDE_PROJECT_DIR=src/claude
API_BASE=http://127.0.0.1:3000
