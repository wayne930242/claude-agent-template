{
  "permissions": {
    "allow": [
      "Bash(bun run:*)",
      "Bash(bun install:*)",
      "Bash(docker build:*)",
      "Bash(docker compose:*)",
      "Bash(curl http://localhost:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/typecheck.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
