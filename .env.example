# ── Required ──────────────────────────────────────────────────────────────────
# OAuth token for Claude Code (starts with sk-ant-oat01-...)
# Get it by running on your host machine: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
API_PORT=3000
API_KEY=
CLAUDE_BIN=claude
CLAUDE_PROJECT_DIR=.
API_BASE=http://127.0.0.1:3000
