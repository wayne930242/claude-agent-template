# API server port
API_PORT=3000

# Optional: protect the API with a key (leave empty for open access in dev)
API_KEY=

# Claude Code binary path (usually 'claude' if installed globally)
CLAUDE_BIN=claude

# Directory where Claude Code runs (your agent's workspace)
CLAUDE_PROJECT_DIR=.

# MCP server base URL (for MCP tools to call the bot API)
API_BASE=http://127.0.0.1:3000
